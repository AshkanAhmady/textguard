{
  "name": "@textguard/dictionaries",
  "version": "0.0.1",
  "description": "Pre-compiled, modular and tree-shakable dictionaries for TextGuard",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts"
  },
  "keywords": [
    "textguard",
    "profanity",
    "dictionary",
    "persian",
    "moderation"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@textguard/core": "workspace:*",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  }
}
