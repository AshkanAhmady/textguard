{
  "name": "@textguard/core",
  "version": "1.0.1",
  "description": "Core package for TextGuard",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "check-types": "tsc --noEmit",
    "test": "vitest",
    "lint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AshkanAhmady/textguard.git"
  },
  "keywords": [
    "profanity",
    "bad-words",
    "moderation",
    "filter",
    "persian",
    "farsi",
    "text-filter"
  ],
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@textguard/fa": "workspace:*",
    "@textguard/en": "workspace:*",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.8"
  }
}
